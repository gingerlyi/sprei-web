// File: prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Int
  stock       Int      @default(0) // <-- INI TAMBAHANNYA
  imageUrls   String[] 
  
  category    String   @default("Sprei Polos")
  size        String   @default("King")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
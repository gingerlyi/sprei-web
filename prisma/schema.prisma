datasource db {
  provider = "postgresql" // Ganti dari "sqlite" menjadi "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Int
  imageUrl    String
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
}
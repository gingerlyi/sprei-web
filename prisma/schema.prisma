datasource db {
  provider = "postgresql" // Ganti dari "sqlite" menjadi "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Int
  imageUrl    String
  
  category    String   @default("Sprei Polos") // <-- TAMBAHKAN BARIS INI
  size        String   @default("King")        // <-- TAMBAHKAN BARIS INI
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}